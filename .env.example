# Copy to .env.local and fill in. None are required to build/run the site.

# Public site URL — used for metadata, OG images, sitemap and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://devvault.vercel.app

# Resend (contact form email). If RESEND_API_KEY is absent, the contact form
# validates input and no-ops cleanly so the site still builds and deploys.
RESEND_API_KEY=
# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=tarikfilipovic1234@gmail.com
# Sender. Until a custom domain is verified in Resend, the onboarding sender
# (the default) works and delivers to the account owner's address.
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# Asset flags — set to 1 once the corresponding files exist under /public so
# the UI swaps placeholders for the real assets.
NEXT_PUBLIC_HAS_SCREENSHOTS=   # /public/projects/<slug>.png
NEXT_PUBLIC_HAS_PHOTO=         # /public/tarik.jpg
NEXT_PUBLIC_HAS_CV=            # /public/cv/Tarik-Filipovic-CV.pdf
